{
  "name": "bossman-mctb",
  "version": "2.0.0",
  "description": "BossMan MCTB - Missed Call Text Back automation for contractors",
  "main": "server/index.ts",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "tsc && vite build",
    "start": "NODE_ENV=production node dist/server/index.js",
    "call-handler": "node call-handling/webhook-server.js",
    "customer-setup": "node customer-setup/onboarding-flow.js",
    "dev-full": "concurrently \"npm run dev\" \"npm run call-handler\" \"npm run customer-setup\"",
    "test": "echo \"Tests not implemented yet\" && exit 0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "express": "^4.18.2",
    "twilio": "^4.20.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0"
  }
}